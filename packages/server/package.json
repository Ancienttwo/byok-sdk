{
  "name": "@byok/server",
  "version": "0.0.1",
  "description": "BYOK SDK server: in-memory M0 reference implementation of the SaaS-side coordinator",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@byok/protocol": "workspace:*",
    "@hono/node-server": "^2.0.10",
    "hono": "^4.12.30",
    "jose": "^6.2.3",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
